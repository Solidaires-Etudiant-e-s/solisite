{
  "name": "solisite",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run prisma:generate && nuxt build",
    "db:push": "npm run db:sync",
    "db:sync": "node scripts/ensure-sqlite-schema.mjs",
    "dev": "npm run db:sync && nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "npm run prisma:generate && nuxt prepare",
    "prisma:generate": "prisma generate",
    "import:articles": "node scripts/import-solidaires-articles.mjs",
    "import:guides": "node scripts/import-solidaires-guides.mjs",
    "import:syndicats": "node scripts/import-solidaires-syndicats.mjs",
    "populate": "npm run db:sync && npm run import:articles && npm run import:guides && npm run import:syndicats",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@iconify-json/simple-icons": "^1.2.75",
    "@nuxt/ui": "^4.6.0",
    "@nuxtjs/leaflet": "^1.3.2",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "7.3.0",
    "ldapts": "^8.1.7",
    "leaflet": "^1.9.4",
    "markdown-it": "^14.1.1",
    "nitro-conditional-middleware": "^0.1.3",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "tiptap-extension-resize-image": "^1.3.3",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@iconify-json/mingcute": "^1.2.7",
    "@nuxt/eslint": "^1.15.2",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prisma": "7.3.0",
    "typescript": "^6.0.2",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "npm@10.9.4"
}
